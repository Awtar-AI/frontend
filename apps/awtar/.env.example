# Awtar Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it's in .gitignore.

# Backend API base URL (your Nest app)
# - Local: http://localhost:3001 (or whatever port your Nest backend runs on)
# - Staging: https://api-staging.awtar.ai
# - Production: https://api.awtar.ai
NEXT_PUBLIC_API_URL=http://localhost:3001